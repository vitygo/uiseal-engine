{
  "tokens": {
    "colors": {
      "--color-1": "#333333",
      "--color-2": "#555555",
      "--color-3": "#3b82f6",
      "--color-4": "#ffffff",
      "--color-5": "#888888",
      "--color-6": "#ff0000"
    },
    "spacing": [
      8,
      16
    ],
    "fontSizes": [
      14
    ],
    "fontFamilies": [
      "Inter"
    ],
    "radii": [
      4
    ]
  },
  "rules": {
    "no-hardcoded-color": "warn",
    "no-arbitrary-spacing": "warn",
    "no-arbitrary-font-size": "warn",
    "no-unauthorized-font-family": "warn",
    "no-arbitrary-radius": "warn",
    "enforce-contrast": "warn",
    "no-img-without-alt": "error",
    "no-div-button": "warn",
    "no-empty-button": "error",
    "no-missing-form-label": "error",
    "no-positive-tabindex": "warn",
    "no-autofocus": "warn",
    "no-xss-dangerous": "error",
    "no-env-in-client": "error",
    "no-console-sensitive": "warn",
    "no-hardcoded-credentials": "error"
  },
  "wcag": {
    "level": "AA"
  },
  "ignore": []
}
